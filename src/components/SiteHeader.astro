---
import HeaderSearch from "@/components/HeaderSearch";
import { loadSite } from "@/lib/data";
import { withBase } from "@/lib/paths";

const site = loadSite();
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href={withBase("/")} aria-label={site.name}>
      <img src={withBase("/assets/logo.png")} alt={site.name} width="200" height="48" />
    </a>
    <nav class="main-nav" id="mainNav" aria-label="Основная навигация">
      <a href={withBase("/catalog/")}>Каталог</a>
      <a href={withBase("/cities/")}>Города</a>
      <a href={withBase("/delivery/")}>Доставка</a>
      <a href={withBase("/about/")}>О компании</a>
      <a href={withBase("/contacts/")}>Контакты</a>
    </nav>
    <HeaderSearch client:load />
    <div class="header-actions">
      <a class="phone-link" href={`tel:${site.phone.replace(/\s/g, "")}`} data-goal="phone_click">{site.phone}</a>
      <button class="btn btn--ghost quote-badge" type="button" id="openQuoteBtn" aria-label="Список заявки">
        Заявка
        <span class="quote-badge__count" id="headerQuoteCount" hidden>0</span>
      </button>
      <a class="btn btn--accent" href={withBase("/contacts/#request")}>Расчёт</a>
    </div>
    <button class="menu-toggle" type="button" id="menuToggle" aria-label="Меню" aria-expanded="false" aria-controls="sideMenu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>

<div class="side-menu-backdrop" id="sideMenuBackdrop" hidden></div>
<aside class="side-menu" id="sideMenu" aria-hidden="true" aria-label="Мобильное меню">
  <div class="side-menu__header">
    <span class="side-menu__title">Меню</span>
    <button class="btn btn--ghost btn--sm" type="button" id="sideMenuClose" aria-label="Закрыть меню">Закрыть</button>
  </div>
  <nav class="side-menu__nav">
    <a href={withBase("/catalog/")}>Каталог</a>
    <a href={withBase("/cities/")}>Города</a>
    <a href={withBase("/delivery/")}>Доставка</a>
    <a href={withBase("/about/")}>О компании</a>
    <a href={withBase("/contacts/")}>Контакты</a>
  </nav>
  <div class="side-menu__footer">
    <a class="btn btn--steel" href={`tel:${site.phone.replace(/\s/g, "")}`} data-goal="phone_click">{site.phone}</a>
    <a class="btn btn--accent" href={withBase("/contacts/#request")}>Заявка на расчёт</a>
  </div>
</aside>

<script>
  const toggle = document.getElementById("menuToggle");
  const backdrop = document.getElementById("sideMenuBackdrop");
  const panel = document.getElementById("sideMenu");
  const closeBtn = document.getElementById("sideMenuClose");
  function setMenuOpen(open) {
    panel?.classList.toggle("is-open", open);
    backdrop?.toggleAttribute("hidden", !open);
    panel?.setAttribute("aria-hidden", String(!open));
    toggle?.setAttribute("aria-expanded", String(open));
    document.body.classList.toggle("menu-open", open);
  }

  toggle?.addEventListener("click", () => setMenuOpen(!panel?.classList.contains("is-open")));
  closeBtn?.addEventListener("click", () => setMenuOpen(false));
  backdrop?.addEventListener("click", () => setMenuOpen(false));
  panel?.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => setMenuOpen(false)));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setMenuOpen(false);
  });
</script>
