---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Хлебные крошки">
  {items.map((item, i) => (
    <>
      {i > 0 && <span aria-hidden="true">/</span>}
      {item.href ? (
        <a href={item.href}>{item.label}</a>
      ) : (
        <span>{item.label}</span>
      )}
    </>
  ))}
</nav>
