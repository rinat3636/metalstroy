---
import { loadSite } from "@/lib/data";
import { withBase } from "@/lib/paths";
import { buildWebSiteSchema } from "@/lib/seo";
import { subdomainUrl } from "@/lib/subdomains";
import { loadCategories } from "@/lib/catalog-live";
import citiesData from "@/data/cities.json";
import type { City } from "@/lib/types";

const site = loadSite();

const cities = citiesData as City[];
const topCategories = loadCategories().slice(0, 6);

const hasRequisites = site.inn || site.kpp || site.ogrn;
---

<footer class="site-footer" id="contacts">
  <div class="container site-footer__grid">
    <div>
      <img src={withBase("/assets/logo.png")} alt={site.name} width="180" height="44" class="footer-logo" />
      <p>{site.name}. {site.tagline} для частного строительства, подрядчиков и организаций.</p>
    </div>
    <address>
      <strong>Контакты</strong>
      <a href={`tel:${site.phone.replace(/\s/g, "")}`} data-goal="phone_click">{site.phone}</a>
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <a href={site.telegram} target="_blank" rel="noopener noreferrer">Telegram</a>
      <a href={site.whatsapp} target="_blank" rel="noopener noreferrer">WhatsApp</a>
      <span>{site.address}</span>
      <span>{site.schedule}</span>
    </address>
    <div>
      <strong>Реквизиты</strong>
      {hasRequisites ? (
        <p>
          {site.legalName}<br />
          {site.inn && <>ИНН: {site.inn}<br /></>}
          {site.kpp && <>КПП: {site.kpp}<br /></>}
          {site.ogrn && <>ОГРН: {site.ogrn}</>}
        </p>
      ) : (
        <p>
          {site.legalName}<br />
          Полные реквизиты для счёта — по запросу менеджера.
        </p>
      )}
    </div>
    <nav class="site-footer__nav" aria-label="Навигация по сайту">
      <div>
        <strong>Каталог</strong>
        {topCategories.map((cat) => (
          <a href={subdomainUrl(cat.slug)}>{cat.name}</a>
        ))}
        <a href={withBase("/catalog/")}>Весь каталог</a>
      </div>
      <div>
        <strong>Города ДНР</strong>
        {cities.slice(0, 6).map((city) => (
          <a href={subdomainUrl(city.slug)}>{city.name}</a>
        ))}
        <a href={withBase("/cities/")}>Все города</a>
      </div>
      <div>
        <strong>Компания</strong>
        <a href={withBase("/about/")}>О компании</a>
        <a href={withBase("/delivery/")}>Доставка</a>
        <a href={withBase("/contacts/")}>Контакты</a>
      </div>
    </nav>
  </div>
</footer>
