---
import { getYandexConfig } from "@/lib/yandex-config";
import { loadSite } from "@/lib/data";

const yandex = getYandexConfig();
const site = loadSite();
---

{(yandex.mapIframeSrc || yandex.mapsUrl) && (
  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow">Склад на карте</p>
      <h2 class="section-title" style="font-size: 1.375rem;">Как нас найти</h2>
      {yandex.mapIframeSrc ? (
        <div class="map-embed" style="margin-top: 1rem; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--color-border);">
          <iframe
            src={yandex.mapIframeSrc}
            title={`${site.name} на Яндекс.Картах`}
            width="100%"
            height="400"
            style="border: 0; display: block;"
            loading="lazy"
            allowfullscreen
          />
        </div>
      ) : (
        <p style="margin-top: 1rem;">
          <a class="btn btn--outline" href={yandex.mapsUrl} target="_blank" rel="noopener noreferrer" data-goal="yandex_map_click">
            Открыть в Яндекс.Картах
          </a>
        </p>
      )}
    </div>
  </section>
)}
