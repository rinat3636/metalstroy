---
import "@/styles/global.css";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import MobileBar from "@/components/MobileBar.astro";
import QuoteApp from "@/components/QuoteApp";
import Analytics from "@/components/Analytics.astro";
import { site } from "@/lib/data";
import { withBase } from "@/lib/paths";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description,
  canonical,
  schema,
  noindex = false,
  ogImage,
  ogType = "website",
} = Astro.props;
const fullTitle = title.includes(site.name) ? title : `${title} — ${site.name}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL(withBase("/assets/hero-warehouse.jpg"), Astro.site).href;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: site.name,
  legalName: site.legalName,
  description: site.tagline,
  telephone: site.phone,
  email: site.email,
  address: {
    "@type": "PostalAddress",
    addressRegion: "ДНР",
    streetAddress: site.address,
  },
  openingHours: "Mo-Sa 08:00-18:00",
  url: Astro.site,
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#1a1f26" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={withBase("/assets/logo.png")} type="image/png" />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Onest:wght@400;500;600;700;800&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(
        Array.isArray(schema) ? schema : schema
      )} />
    )}
  </head>
  <body>
    <div class="top-strip">
      <div class="container top-strip__inner">
        <span>Поставка металлопроката и стройматериалов по ДНР</span>
        <span>{site.schedule} · Самовывоз и доставка по согласованию</span>
      </div>
    </div>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
    <MobileBar />
    <QuoteApp client:load />
    <Analytics />
  </body>
</html>
