---
import "@/styles/global.css";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import MobileBar from "@/components/MobileBar.astro";
import QuoteApp from "@/components/QuoteApp";
import Analytics from "@/components/Analytics.astro";
import { loadSite } from "@/lib/data";
import { withBase } from "@/lib/paths";
import { buildWebSiteSchema } from "@/lib/seo";
import { getYandexConfig } from "@/lib/yandex-config";
import { getSiteOrigin } from "@/lib/subdomains";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description,
  canonical,
  schema,
  noindex = false,
  ogImage,
  ogType = "website",
} = Astro.props;
const site = loadSite();
const yandex = getYandexConfig();
const siteOrigin = getSiteOrigin();
const fullTitle = title.includes(site.name) ? title : `${title} — ${site.name}`;
const canonicalUrl = canonical ?? Astro.url.href.split("?")[0];
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL(withBase("/assets/hero-warehouse.jpg"), Astro.site).href;

const orgSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${siteOrigin}/#organization`,
  name: site.name,
  legalName: site.legalName,
  description: site.tagline,
  telephone: site.phone,
  email: site.email,
  image: new URL(withBase("/assets/hero-warehouse.jpg"), Astro.site).href,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Донецк",
    addressRegion: "ДНР",
    addressCountry: "RU",
    streetAddress: site.address,
  },
  areaServed: {
    "@type": "AdministrativeArea",
    name: "Донецкая Народная Республика",
  },
  openingHours: "Mo-Sa 08:00-18:00",
  priceRange: "₽₽",
  url: siteOrigin,
};

if (site.yandexMaps) {
  orgSchema.hasMap = site.yandexMaps;
}

if (site.geoLat && site.geoLng) {
  orgSchema.geo = {
    "@type": "GeoCoordinates",
    latitude: site.geoLat,
    longitude: site.geoLng,
  };
}

const sameAs = [site.telegram, site.whatsapp, site.yandexMaps, site.gis2].filter(Boolean);
if (sameAs.length > 0) {
  orgSchema.sameAs = sameAs;
}

const websiteSchema = buildWebSiteSchema();
const jsonLd = [orgSchema, websiteSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {yandex.verification && <meta name="yandex-verification" content={yandex.verification} />}
    <meta name="geo.region" content="RU-DON" />
    <meta name="geo.placename" content="Донецк" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#1a1f26" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={withBase("/assets/logo.png")} type="image/png" />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Onest:wght@400;500;600;700;800&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div class="top-strip">
      <div class="container top-strip__inner">
        <span>Поставка металлопроката и стройматериалов по ДНР</span>
        <span>{site.schedule} · Самовывоз и доставка по согласованию</span>
      </div>
    </div>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
    <MobileBar />
    <QuoteApp client:load />
    <Analytics />
  </body>
</html>
