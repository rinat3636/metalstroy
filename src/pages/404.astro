---
import Layout from "@/layouts/Layout.astro";
import { withBase } from "@/lib/paths";
import { loadCategories } from "@/lib/catalog-live";
import { subdomainUrl } from "@/lib/subdomains";

export const prerender = false;

Astro.response.status = 404;

const categories = loadCategories().slice(0, 6);
---

<Layout
  title="Страница не найдена"
  description="Запрошенная страница не найдена. Перейдите в каталог металлопроката Профсталь-инвест или оставьте заявку."
  noindex={true}
>
  <section class="section">
    <div class="container" style="text-align: center; max-width: 36rem; margin: 0 auto;">
      <p class="eyebrow">404</p>
      <h1 class="section-title">Страница не найдена</h1>
      <p class="section-lead">Возможно, адрес изменился или позиция снята с витрины.</p>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-top: 1.5rem;">
        <a class="btn btn--accent" href={withBase("/")}>На главную</a>
        <a class="btn btn--outline" href={withBase("/catalog/")}>Каталог</a>
        <a class="btn btn--outline" href={withBase("/contacts/")}>Контакты</a>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow">Популярные категории</p>
      <div class="city-grid city-grid--compact">
        {categories.map((cat) => (
          <a class="city-card city-card--link" href={subdomainUrl(cat.slug)}>
            <h3>{cat.name}</h3>
            <p>{cat.count} позиций</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
