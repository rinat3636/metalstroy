---
import Layout from "@/layouts/Layout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import LeadForm from "@/components/LeadForm";
import { cities, site, productImageUrl, formatPrice, loadSite } from "@/lib/data";
import { getProductBySku, loadCategories } from "@/lib/catalog-live";
import { buildBreadcrumbSchema, buildFaqSchema, canonicalForPage, absoluteUrl } from "@/lib/seo";
import { cityFaq, cityMetaDescription, cityMetaTitle } from "@/lib/city-seo";
import { cityProductUrl } from "@/lib/city-product-seo";
import { subdomainUrl } from "@/lib/subdomains";
import { withBase } from "@/lib/paths";

export const prerender = false;

const { slug } = Astro.params;
const siteLive = loadSite();
const city = cities.find((c) => c.slug === slug);
if (!city) return Astro.redirect(withBase("/"));

const categories = loadCategories();
const canonical = canonicalForPage({
  pathname: Astro.url.pathname,
  citySlug: city.slug,
});

const cityHomeUrl = subdomainUrl(city.slug);

const popularProducts = (city.popularSkus ?? [])
  .map((sku) => getProductBySku(sku))
  .filter(Boolean);

const faq = cityFaq(city);

const faqSchema = buildFaqSchema(faq);
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Главная", href: absoluteUrl("/") },
  { name: "Города", href: absoluteUrl("/cities/") },
  { name: city.name },
]);
---

<Layout
  title={cityMetaTitle(city, siteLive.name)}
  description={cityMetaDescription(city)}
  canonical={canonical}
  schema={[faqSchema, breadcrumbSchema]}
>
  <div class="page-header">
    <div class="container">
      <Breadcrumbs items={[
        { label: "Главная", href: "/" },
        { label: "Города", href: "/cities/" },
        { label: city.name },
      ]} />
      <p class="eyebrow">География</p>
      <h1 class="section-title">{city.title}</h1>
      <p class="section-lead">{city.text}</p>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <p class="section-lead" style="margin-bottom: 1rem;">{city.delivery}</p>
      {city.highlights && city.highlights.length > 0 && (
        <ul class="city-highlights">
          {city.highlights.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      )}
      {popularProducts.length > 0 && (
        <>
          <p class="eyebrow" style="margin-top: 1.5rem;">Ходовые позиции</p>
          <div class="product-grid" style="margin: 1rem 0 1.5rem;">
            {popularProducts.map((product) => product && (
              <a href={cityProductUrl(city.slug, product)} class="related-card">
                <div class="related-card__media">
                  <img src={productImageUrl(product.image)} alt={`${product.title} — ${product.sku}`} loading="lazy" width="200" height="150" />
                </div>
                <div class="related-card__body">
                  <h3>{product.title}</h3>
                  <p>{formatPrice(product.price)}</p>
                </div>
              </a>
            ))}
          </div>
        </>
      )}
      <p class="eyebrow">Категории в {city.name}</p>
      <div class="category-grid">
        {categories.map((cat) => (
          <a href={subdomainUrl(city.slug, `/${cat.slug}/`)} class="category-card">
            <span class="category-card__count">{cat.count} позиций</span>
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">FAQ</p>
      <h2 class="section-title">Частые вопросы — {city.name}</h2>
      <div class="faq-list" style="margin-top: 1.5rem;">
        {faq.map((item) => (
          <article class="faq-item">
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section request-section">
    <div class="container request-grid">
      <div>
        <p class="eyebrow">Заявка</p>
        <h2 class="section-title" style="color: #fff;">Расчёт для {city.name}</h2>
        <p class="section-lead">Оставьте контакты — менеджер перезвонит с актуальной ценой и сроками.</p>
      </div>
      <LeadForm client:load defaultCity={city.name} />
    </div>
  </section>
</Layout>
