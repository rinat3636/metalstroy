---
import Layout from "@/layouts/Layout.astro";
import CatalogBrowser from "@/components/CatalogBrowser";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { categories, productImageUrl } from "@/lib/data";
import { getCategoryBySlug, loadProducts } from "@/lib/product-store";
import { withBase } from "@/lib/paths";

export function getStaticPaths() {
  return categories.map((category) => ({ params: { categorySlug: category.slug } }));
}

const { categorySlug } = Astro.params;
const category = getCategoryBySlug(categorySlug!);
if (!category) return Astro.redirect(withBase("/catalog/"));

const categoryProducts = loadProducts().filter((p) => p.categorySlug === categorySlug);
---

<Layout
  title={`${category.name} — купить в ДНР`}
  description={category.description}
>
  <div class="page-header">
    <div class="container page-header__split">
      <div>
        <Breadcrumbs items={[
          { label: "Главная", href: "/" },
          { label: "Каталог", href: "/catalog/" },
          { label: category.name },
        ]} />
        <p class="eyebrow">Категория</p>
        <h1 class="section-title">{category.name}</h1>
        <p class="section-lead">{category.description}</p>
      </div>
      {category.image && (
        <div class="page-header__visual">
          <img src={productImageUrl(category.image)} alt={category.name} width="480" height="300" loading="eager" />
        </div>
      )}
    </div>
  </div>
  <section class="section section--tight">
    <div class="container">
      <CatalogBrowser client:load products={categoryProducts} initialCategory={category.name} />
      <div class="seo-block">
        <p>{category.seoText}</p>
      </div>
    </div>
  </section>
</Layout>
