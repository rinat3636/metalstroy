---
import Layout from "@/layouts/Layout.astro";
import CatalogBrowser from "@/components/CatalogBrowser";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { productImageUrl, getCategoryCoverImage } from "@/lib/data";
import { getCategoryBySlug, loadProducts } from "@/lib/product-store";
import { withBase } from "@/lib/paths";

export const prerender = false;

const { categorySlug } = Astro.params;
const category = getCategoryBySlug(categorySlug!);
if (!category) return Astro.redirect(withBase("/catalog/"));

const categoryProducts = loadProducts().filter((p) => p.categorySlug === categorySlug);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Главная", item: Astro.site },
    { "@type": "ListItem", position: 2, name: "Каталог", item: new URL(withBase("/catalog/"), Astro.site).href },
    { "@type": "ListItem", position: 3, name: category.name },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: category.name,
  numberOfItems: categoryProducts.length,
  itemListElement: categoryProducts.slice(0, 20).map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: new URL(withBase(`/catalog/${p.categorySlug}/${p.slug}/`), Astro.site).href,
    name: p.title,
  })),
};
---

<Layout
  title={`${category.name} — купить в ДНР`}
  description={category.description}
  schema={[breadcrumbSchema, itemListSchema]}
  ogImage={getCategoryCoverImage(categorySlug!) ? productImageUrl(getCategoryCoverImage(categorySlug!)) : undefined}
>
  <div class="page-header">
    <div class="container page-header__split">
      <div>
        <Breadcrumbs items={[
          { label: "Главная", href: "/" },
          { label: "Каталог", href: "/catalog/" },
          { label: category.name },
        ]} />
        <p class="eyebrow">Категория</p>
        <h1 class="section-title">{category.name}</h1>
        <p class="section-lead">{category.description}</p>
      </div>
      {getCategoryCoverImage(categorySlug!) && (
        <div class="page-header__visual">
          <img src={productImageUrl(getCategoryCoverImage(categorySlug!))} alt={category.name} width="480" height="300" loading="eager" />
        </div>
      )}
    </div>
  </div>
  <section class="section section--tight">
    <div class="container">
      <CatalogBrowser client:load products={categoryProducts} initialCategory={category.name} />
      <div class="seo-block">
        <p>{category.seoText}</p>
      </div>
    </div>
  </section>
</Layout>
