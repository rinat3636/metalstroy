---
import Layout from "@/layouts/Layout.astro";
import CatalogBrowser from "@/components/CatalogBrowser";
import ProductCard from "@/components/ProductCard.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { productImageUrl } from "@/lib/data";
import { getCategoryCoverImage } from "@/lib/catalog-live";
import { getCategoryBySlug, loadProducts } from "@/lib/product-store";
import { absoluteUrl, canonicalForPage, buildBreadcrumbSchema } from "@/lib/seo";
import { subdomainUrl } from "@/lib/subdomains";
import citiesData from "@/data/cities.json";
import type { City } from "@/lib/types";
import { withBase } from "@/lib/paths";

const cities = citiesData as City[];

export const prerender = false;

const { categorySlug } = Astro.params;
const category = getCategoryBySlug(categorySlug!);
if (!category) return Astro.redirect(withBase("/catalog/"));

const categoryProducts = loadProducts().filter((p) => p.categorySlug === categorySlug);
const ssrProducts = categoryProducts.slice(0, 20);

const canonical = canonicalForPage({
  pathname: Astro.url.pathname,
  categorySlug: category.slug,
});

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Главная", href: absoluteUrl("/") },
  { name: "Каталог", href: absoluteUrl("/catalog/") },
  { name: category.name },
]);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: category.name,
  numberOfItems: categoryProducts.length,
  itemListElement: categoryProducts.slice(0, 20).map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: absoluteUrl(`/catalog/${p.categorySlug}/${p.slug}/`),
    name: p.title,
  })),
};
---

<Layout
  title={`${category.name} — купить в ДНР | ${category.count} позиций`}
  description={`${category.description} ${category.seoText.slice(0, 120)}`}
  canonical={canonical}
  schema={[breadcrumbSchema, itemListSchema]}
  ogImage={getCategoryCoverImage(categorySlug!) ? productImageUrl(getCategoryCoverImage(categorySlug!)) : undefined}
>
  <div class="page-header">
    <div class="container page-header__split">
      <div>
        <Breadcrumbs items={[
          { label: "Главная", href: absoluteUrl("/") },
          { label: "Каталог", href: absoluteUrl("/catalog/") },
          { label: category.name },
        ]} />
        <p class="eyebrow">Категория</p>
        <h1 class="section-title">{category.name}</h1>
        <p class="section-lead">{category.description}</p>
      </div>
      {getCategoryCoverImage(categorySlug!) && (
        <div class="page-header__visual">
          <img src={productImageUrl(getCategoryCoverImage(categorySlug!))} alt={category.name} width="480" height="300" loading="eager" />
        </div>
      )}
    </div>
  </div>
  <section class="section section--tight">
    <div class="container catalog-section">
      <div class="product-grid catalog-ssr">
        {ssrProducts.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
      <CatalogBrowser client:visible products={categoryProducts} initialCategory={category.name} />
      <div class="seo-block">
        <p>{category.seoText}</p>
      </div>
      <div class="seo-block">
        <h2>{category.name} — поставка по городам ДНР</h2>
        <div class="city-grid city-grid--compact">
          {cities.map((city) => (
            <a class="city-card city-card--link" href={subdomainUrl(city.slug, `/${category.slug}/`)}>
              <h3>{city.name}</h3>
              <p>{category.name} · {city.name}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
