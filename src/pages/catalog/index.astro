---
import Layout from "@/layouts/Layout.astro";
import CatalogBrowser from "@/components/CatalogBrowser";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { loadCategories, loadProducts } from "@/lib/catalog-live";
import { absoluteUrl, buildBreadcrumbSchema } from "@/lib/seo";
import { subdomainUrl } from "@/lib/subdomains";

const categories = loadCategories();
const products = loadProducts();
const canonical = absoluteUrl("/catalog/");

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Главная", href: absoluteUrl("/") },
  { name: "Каталог" },
]);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Каталог металлопроката",
  numberOfItems: products.length,
  itemListElement: categories.slice(0, 12).map((cat, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: cat.name,
    url: subdomainUrl(cat.slug),
  })),
};
---

<Layout
  title="Каталог металлопроката и стройматериалов в ДНР"
  description={`Каталог ${products.length} позиций в ${categories.length} категориях: трубы, арматура, лист, профнастил, сетки, кровля. Поставка по ДНР, расчёт онлайн.`}
  canonical={canonical}
  schema={[breadcrumbSchema, itemListSchema]}
>
  <div class="page-header">
    <div class="container">
      <Breadcrumbs items={[
        { label: "Главная", href: "/" },
        { label: "Каталог" },
      ]} />
      <p class="eyebrow">Каталог</p>
      <h1 class="section-title">Металлопрокат, кровля, сетки и стройматериалы</h1>
      <p class="section-lead">{products.length} позиций в {categories.length} категориях. Цены и остатки уточняет менеджер.</p>
    </div>
  </div>
  <section class="section section--tight">
    <div class="container">
      <div class="city-grid city-grid--compact">
        {categories.map((cat) => (
          <a class="city-card city-card--link" href={subdomainUrl(cat.slug)}>
            <h2 style="font-size: 1.125rem; margin: 0;">{cat.name}</h2>
            <p>{cat.count} позиций</p>
          </a>
        ))}
      </div>
      <div class="seo-block" style="margin-top: 2rem;">
        <h2 class="section-title" style="font-size: 1.25rem;">Металлопрокат оптом и в розницу по ДНР</h2>
        <p>
          Профсталь-инвест — складская программа металлопроката и стройматериалов для частных заказчиков,
          подрядчиков и организаций. Подбор по размерам, расчёт партии, доставка по Донецку, Макеевке,
          Горловке и другим городам региона.
        </p>
      </div>
      <CatalogBrowser client:visible />
    </div>
  </section>
</Layout>
