---
import Layout from "@/layouts/Layout.astro";
import CatalogBrowser from "@/components/CatalogBrowser";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { loadCategories } from "@/lib/catalog-live";
import { subdomainUrl } from "@/lib/subdomains";

const categories = loadCategories();
---

<Layout
  title="Каталог металлопроката и стройматериалов"
  description="Каталог Профсталь-инвест: трубы, арматура, лист, профнастил, сетки, кровля и крепёж. Фильтры по категории и наличию."
>
  <div class="page-header">
    <div class="container">
      <Breadcrumbs items={[
        { label: "Главная", href: "/" },
        { label: "Каталог" },
      ]} />
      <p class="eyebrow">Каталог</p>
      <h1 class="section-title">Металлопрокат, кровля, сетки и стройматериалы</h1>
      <p class="section-lead">Цены и остатки требуют подтверждения менеджером. Подберём аналоги, если нужной позиции нет в наличии.</p>
    </div>
  </div>
  <section class="section section--tight">
    <div class="container">
      <div class="city-grid city-grid--compact">
        {categories.map((cat) => (
          <a class="city-card city-card--link" href={subdomainUrl(cat.slug)}>
            <h3>{cat.name}</h3>
            <p>{cat.count} позиций · {subdomainUrl(cat.slug).replace("https://", "")}</p>
          </a>
        ))}
      </div>
      <CatalogBrowser client:visible />
    </div>
  </section>
</Layout>
