---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import LeadForm from "@/components/LeadForm";
import ProductCard from "@/components/ProductCard.astro";
import { site, productImageUrl, cities } from "@/lib/data";
import { getCategoryCoverImage, getFeaturedProducts, loadCategories, loadProducts } from "@/lib/catalog-live";
import { absoluteUrl, buildFaqSchema } from "@/lib/seo";
import { subdomainUrl } from "@/lib/subdomains";
import { withBase } from "@/lib/paths";

const products = loadProducts();
const featuredProducts = getFeaturedProducts();
const categories = loadCategories();

const topCategories = categories.slice(0, 6);
const homeCanonical = absoluteUrl("/");

const homeFaq = [
  { q: "Как оформить заказ металлопроката?", a: "Выберите позиции в каталоге, добавьте в заявку или позвоните — менеджер уточнит цену, наличие и сроки доставки по ДНР." },
  { q: "Куда доставляете?", a: "Донецк, Макеевка, Горловка, Енакиево, Харцызск, Шахтёрск, Торез, Снежное, Ясиноватая, Мариуполь и другие населённые пункты ДНР." },
  { q: "Работаете с юридическими лицами?", a: "Да — выставляем счёт, предоставляем закрывающие документы, поставляем партиями под объект." },
];
const faqSchema = buildFaqSchema(homeFaq);
---

<Layout
  title={`${site.name} — металлопрокат и стройматериалы в ДНР`}
  description="Профсталь-инвест: каталог металлопроката и стройматериалов в ДНР. Трубы, арматура, лист, профнастил, сетки, кровля. Подбор, расчёт и поставка по региону."
  canonical={homeCanonical}
  schema={faqSchema}
>
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__copy">
        <p class="eyebrow">{site.name}</p>
        <h1>Металлопрокат и стройматериалы в ДНР</h1>
        <p class="hero__lead">
          Комплектуем частные стройки, подрядчиков и организации: профильная труба, арматура, лист,
          профнастил, сетка, крепёж и кровельные материалы.
        </p>
        <div class="hero__tags">
          <span>Складская программа</span>
          <span>Партии под объект</span>
          <span>Доставка по согласованию</span>
        </div>
        <div class="hero__actions">
          <a class="btn btn--accent" href={withBase("/catalog/")}>Открыть каталог</a>
          <a class="btn btn--outline" href={withBase("/contacts/#request")}>Запросить расчёт</a>
        </div>
        <dl class="hero__facts">
          <div>
            <dt>{products.length}</dt>
            <dd>позиций в каталоге</dd>
          </div>
          <div>
            <dt>опт / розница</dt>
            <dd>под частные и строительные задачи</dd>
          </div>
          <div>
            <dt>ДНР</dt>
            <dd>самовывоз или доставка</dd>
          </div>
        </dl>
      </div>
      <aside class="hero-panel">
        <div class="hero-panel__image">
          <img
            src={withBase("/assets/hero-warehouse.jpg")}
            alt="Металлопрокат на складе — трубы, арматура, лист"
            width="800"
            height="450"
            loading="eager"
            fetchpriority="high"
          />
          <div class="hero-panel__caption">
            <span class="hero-panel__caption-title">Склад металлопроката</span>
            <span>Отгрузка в день обращения — по согласованию</span>
          </div>
        </div>
        <div class="hero-panel__body">
          <p class="hero-panel__label">Популярные категории</p>
          <div class="supply-list">
            {topCategories.map((cat) => {
              const cover = getCategoryCoverImage(cat.slug);
              return (
                <a href={subdomainUrl(cat.slug)}>
                  {cover && (
                    <img
                      class="supply-list__thumb"
                      src={productImageUrl(cover)}
                      alt=""
                      width="40"
                      height="40"
                      loading="lazy"
                    />
                  )}
                  <span>{cat.name}</span>
                  <small>{cat.count} поз.</small>
                </a>
              );
            })}
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--tight section--mobile-compact">
    <div class="container trust-grid">
      <article class="trust-card">
        <strong>Под объект</strong>
        <span>Подберём позиции по размерам, объёму и назначению.</span>
      </article>
      <article class="trust-card">
        <strong>По наличию</strong>
        <span>Уточним остатки и предложим подходящую замену.</span>
      </article>
      <article class="trust-card">
        <strong>Для организаций</strong>
        <span>Счёт, закрывающие документы, работа с партиями.</span>
      </article>
      <article class="trust-card">
        <strong>По региону</strong>
        <span>Самовывоз или доставка по согласованному маршруту.</span>
      </article>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow">География</p>
      <h2 class="section-title">Поставка металлопроката по городам ДНР</h2>
      <p class="section-lead">Подберём позиции под объект, уточним наличие и согласуем доставку или самовывоз.</p>
      <div class="city-grid city-grid--compact" style="margin-top: 1.25rem;">
        {cities.map((city) => (
          <a class="city-card city-card--link" href={subdomainUrl(city.slug)}>
            <h3>{city.name}</h3>
            <p>{city.title}</p>
          </a>
        ))}
      </div>
      <div style="margin-top: 1.25rem;">
        <a class="btn btn--outline" href={withBase("/cities/")}>Все города поставки</a>
      </div>
    </div>
  </section>

  <section class="section section--mobile-compact">
    <div class="container">
      <p class="eyebrow">Как работаем</p>
      <h2 class="section-title only-desktop">От подбора позиции до отгрузки без лишних шагов</h2>
      <h2 class="section-title only-mobile">4 шага до отгрузки</h2>
      <p class="section-lead only-mobile" style="margin-bottom: 0;">Подбор, проверка наличия, расчёт и отгрузка.</p>
      <div class="process">
        <span><b>01</b> Выбор позиции</span>
        <span><b>02</b> Проверка наличия</span>
        <span><b>03</b> Расчёт партии</span>
        <span><b>04</b> Отгрузка</span>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow">География</p>
      <h2 class="section-title">Поставка металлопроката по городам ДНР</h2>
      <p class="section-lead">Подберём позиции под объект, уточним наличие и согласуем доставку или самовывоз.</p>
      <div class="city-grid city-grid--compact" style="margin-top: 1.25rem;">
        {cities.map((city) => (
          <a class="city-card city-card--link" href={subdomainUrl(city.slug)}>
            <h3>{city.name}</h3>
            <p>{city.title}</p>
          </a>
        ))}
      </div>
      <div style="margin-top: 1.25rem;">
        <a class="btn btn--outline" href={withBase("/cities/")}>Все города поставки</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Хиты продаж</p>
      <h2 class="section-title">Ходовые позиции</h2>
      <p class="section-lead">Цены и остатки требуют подтверждения менеджером. Подберём аналоги, если нужной позиции нет в наличии.</p>
      <div class="product-grid product-grid--featured" style="margin-top: 1.25rem;">
        {featuredProducts.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
      <div style="margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 0.75rem;">
        <a class="btn btn--accent" href={withBase("/catalog/")}>Весь каталог</a>
        <a class="btn btn--outline" href={withBase("/contacts/#request")}>Запросить расчёт</a>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll(".js-add-quote").forEach((btn) => {
      btn.addEventListener("click", () => {
        const sku = btn.getAttribute("data-sku");
        const title = btn.getAttribute("data-title");
        if (!sku || !title) return;
        (window as unknown as { addToQuote?: (item: { sku: string; title: string }) => void }).addToQuote?.({
          sku,
          title,
        });
      });
    });
  </script>

  <section class="section">
    <div class="container split-grid">
      <div>
        <p class="eyebrow">Сервис</p>
        <h2 class="section-title">Подбор по размерам, резка по задаче, доставка по согласованию</h2>
        <p class="section-lead">Каталог помогает быстро подобрать позиции. Итоговая стоимость зависит от объёма, длины, остатков, доставки и текущей закупки.</p>
        <a class="btn btn--outline" href={withBase("/delivery/")} style="margin-top: 1rem;">Подробнее о доставке</a>
      </div>
      <div class="service-list">
        <article class="service-card">
          <h3>Для частных клиентов</h3>
          <p>Заборы, навесы, кровля, сетка, профильная труба, расходные позиции для участка и ремонта.</p>
        </article>
        <article class="service-card">
          <h3>Для строителей</h3>
          <p>Арматура, швеллер, уголок, лист, трубы, крепёж и расходные материалы с быстрым расчётом партии.</p>
        </article>
        <article class="service-card">
          <h3>Для организаций</h3>
          <p>Счёт, закрывающие документы и поставка под объект. Реквизиты предоставляются при оформлении заказа.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section request-section">
    <div class="container request-grid">
      <div>
        <p class="eyebrow">Заявка</p>
        <h2 class="section-title" style="color: #fff;">Отправьте список позиций на расчёт</h2>
        <p class="section-lead">Оставьте контакты и список нужных позиций. Менеджер уточнит актуальную цену, наличие и срок доставки.</p>
      </div>
      <LeadForm client:load />
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow">FAQ</p>
      <h2 class="section-title" style="font-size: 1.375rem;">Частые вопросы</h2>
      <div class="faq-list" style="margin-top: 1.5rem;">
        {homeFaq.map((item) => (
          <article class="faq-item">
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
